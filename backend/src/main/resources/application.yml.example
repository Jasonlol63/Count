# Copy to application.yml for local development (application.yml is gitignored).
spring:
  application:
    name: Count

  sql:
    init:
      mode: never

  session:
    store-type: none
    timeout: 1h
    cookie:
      name: JSESSIONID
      http-only: true
      same-site: lax

  datasource:
    driverClassName: com.mysql.cj.jdbc.Driver
    url: jdbc:mysql://localhost:3306/testcount?&serverTimezone=Asia/Shanghai
    username: root
    password: YOUR_DB_PASSWORD
    dbcp2:
      min-idle: 5
      initial-size: 5
      max-total: 5
      max-wait-millis: 150

  redis:
    host: localhost
    port: 6379

  servlet:
    multipart:
      enabled: true
      file-size-threshold: 2KB
      max-file-size: 200MB
      max-request-size: 215MB

  jwt:
    secret: your-very-long-secret-key-at-least-32-characters
    access-token-expiration: 3600000
    refresh-token-expiration: 604800000
    cookie-name: ec_access_token

server:
  port: 8082

mybatis:
  mapper-locations: classpath:mybatis/*.xml
  type-handlers-package: com.eazycount.handler
  configuration:
    map-underscore-to-camel-case: true

file:
  image-dir: backend/src/main/resources/static/
