<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.eazycount.dao.PermissionDao">

    <resultMap id="TenantMap" type="com.eazycount.entity.Tenant">
        <id property="id" column="id"/>
        <result property="tenantType" column="tenant_type"
                typeHandler="com.eazycount.config.mybatis.TenantTypeHandler"/>
        <result property="code" column="code"/>
        <result property="name" column="name"/>
        <result property="ownerId" column="owner_id"/>
        <result property="parentId" column="parent_id"/>
        <result property="expirationDate" column="expiration_date"/>
        <result property="status" column="status"/>
        <result property="createdBy" column="created_by"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
        <result property="categoryCode" column="category_code"
                typeHandler="com.eazycount.handler.JsonStringListTypeHandler"/>
    </resultMap>

    <sql id="TenantColumns">
        id,
        tenant_type,
        code,
        name,
        owner_id,
        parent_id,
        expiration_date,
        category_code,
        status,
        created_by,
        created_at,
        updated_at
    </sql>

    <select id="findTenantById" resultMap="TenantMap">
        SELECT
        <include refid="TenantColumns"/>
        FROM tenant
        WHERE id = #{tenantId}
        AND status = 'ACTIVE'
        LIMIT 1
    </select>

</mapper>
