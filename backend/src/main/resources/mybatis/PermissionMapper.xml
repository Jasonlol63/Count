<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.eazycount.dao.PermissionDao">

    <resultMap id="StaffRoleMap" type="com.eazycount.entity.AdminRole">
        <id property="id" column="id"/>
        <result property="code" column="code"/>
        <result property="name" column="name"/>
        <result property="hierarchyLevel" column="hierarchy_level"/>
        <result property="status" column="status"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <resultMap id="PermissionMap" type="com.eazycount.entity.Permission">
        <id property="id" column="id"/>
        <result property="code" column="code"/>
        <result property="name" column="name"/>
        <result property="sortOrder" column="sort_order"/>
        <result property="requiresFeatureId" column="requires_feature_id"/>
        <result property="status" column="status"/>
    </resultMap>

    <sql id="StaffRoleColumns">
        id,
        code,
        name,
        hierarchy_level,
        status,
        created_at,
        updated_at
    </sql>

    <sql id="PermissionColumns">
        p.id,
        p.code,
        p.name,
        p.sort_order,
        p.requires_feature_id,
        p.status
    </sql>

    <select id="findStaffRoleById" resultMap="StaffRoleMap">
        SELECT
        <include refid="StaffRoleColumns"/>
        FROM user_role
        WHERE id = #{roleId}
          AND status = 'ACTIVE'
        LIMIT 1
    </select>

    <select id="findStaffRoleByCode" resultMap="StaffRoleMap">
        SELECT
        <include refid="StaffRoleColumns"/>
        FROM user_role
        WHERE UPPER(TRIM(code)) = UPPER(TRIM(#{code}))
          AND status = 'ACTIVE'
        LIMIT 1
    </select>

    <select id="findStaffRoleByUserId" resultMap="StaffRoleMap">
        SELECT
        <include refid="StaffRoleColumns"/>
        FROM user_role ur
        INNER JOIN user u ON u.role_id = ur.id
        WHERE u.id = #{userId}
          AND u.status = 'ACTIVE'
          AND ur.status = 'ACTIVE'
        LIMIT 1
    </select>

    <select id="findActivePermissionsByRoleId" resultMap="PermissionMap">
        SELECT
        <include refid="PermissionColumns"/>
        FROM user_role_permission urp
        INNER JOIN permission p ON p.id = urp.permission_id
        WHERE urp.role_id = #{roleId}
          AND p.status = 'ACTIVE'
        ORDER BY p.sort_order ASC, p.id ASC
    </select>

    <select id="findActivePermissionsByCodes" resultMap="PermissionMap">
        SELECT
        <include refid="PermissionColumns"/>
        FROM permission p
        WHERE p.status = 'ACTIVE'
        <if test="codes != null and codes.size() > 0">
            AND UPPER(TRIM(p.code)) IN
            <foreach collection="codes" item="code" open="(" separator="," close=")">
                UPPER(TRIM(#{code}))
            </foreach>
        </if>
        ORDER BY p.sort_order ASC, p.id ASC
    </select>

</mapper>
