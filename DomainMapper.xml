<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.eazycount.dao.DomainDao">
    <resultMap id="OwnerTenantDTO" type="com.eazycount.dto.DomainDTO">
        <result property="parentGroupCode" column="parentGroupCode"/>

        <association property="owner" javaType="com.eazycount.entity.Owner">
            <id property="id" column="ownerId"/>
            <result property="ownerCode" column="ownerCode"/>
            <result property="name" column="ownerName"/>
            <result property="password" column="ownerPassword"/>
            <result property="secondaryPassword" column="ownerSecondaryPassword"/>
            <result property="email" column="ownerEmail"/>
            <result property="status" column="ownerStatus"/>
            <result property="createdBy" column="ownerCreatedBy"/>
            <result property="createdAt" column="ownerCreatedAt"/>
        </association>

        <association property="tenant" javaType="com.eazycount.entity.Tenant">
            <id property="id" column="tenantId"/>
            <result property="tenantType" column="tenantType"/>
            <result property="code" column="tenantCode"/>
            <result property="name" column="tenantName"/>
            <result property="ownerId" column="tenantOwnerId"/>
            <result property="parentId" column="tenantParentId"/>
            <result property="expirationDate" column="tenantExpirationDate"/>
            <result property="FeeShareAllocate" column="tenantFeeShareAllocate"/>
            <result property="status" column="tenantStatus"/>
            <result property="createdBy" column="tenantCreatedBy"/>
            <result property="createdAt" column="tenantCreatedAt"/>
            <result property="updatedAt" column="tenantUpdatedAt"/>
        </association>
    </resultMap>

    <resultMap id="TenantMap" type="com.eazycount.entity.Tenant">
        <id property="id" column="id"/>
        <result property="tenantType" column="tenant_type"/>
        <result property="code" column="code"/>
        <result property="name" column="name"/>
        <result property="ownerId" column="owner_id"/>
        <result property="parentId" column="parent_id"/>
        <result property="expirationDate" column="expiration_date"/>
        <result property="status" column="status"/>
        <result property="createdBy" column="created_by"/>
    </resultMap>

    <resultMap id="DomainFeeMap" type="com.eazycount.entity.DomainFee">
        <id column="id" property="id" jdbcType="TINYINT"/>
        <result column="company_price" property="companyPrice"
                typeHandler="com.eazycount.config.mybatis.PriceMapTypeHandler"/>
        <result column="group_price" property="groupPrice"
                typeHandler="com.eazycount.config.mybatis.PriceMapTypeHandler"/>
        <result column="updated_at" property="updatedTime" jdbcType="TIMESTAMP"/>
    </resultMap>
    
    <select id="countTenantCodeConflict" resultType="int">
        SELECT COUNT(*)
        FROM tenant
        WHERE UPPER(TRIM(code)) = UPPER(TRIM(#{code}))
        <if test="excludeOwnerId != null">
            AND (owner_id IS NULL OR owner_id &lt;&gt; #{excludeOwnerId})
        </if>
    </select>

    <select id="findTenantsByOwnerId" resultMap="TenantMap">
        SELECT id, tenant_type, code, name, owner_id, parent_id, expiration_date, status, created_by
        FROM tenant
        WHERE owner_id = #{ownerId}
        AND status = 'ACTIVE'
    </select>

    <select id="countOwnerCodeConflict" resultType="int">
        SELECT COUNT(*)
        FROM owner
        WHERE UPPER(TRIM(owner_code)) = UPPER(TRIM(#{code}))
        <if test="excludeOwnerId != null">
            AND id &lt;&gt; #{excludeOwnerId}
        </if>
    </select>

    <select id="findAllDomainList" resultMap="OwnerTenantDTO">
        SELECT
        o.id                   AS ownerId,
        o.owner_code           AS ownerCode,
        o.name                 AS ownerName,
        o.email                AS ownerEmail,
        o.created_by           AS ownerCreatedBy,
        o.created_at           AS ownerCreatedAt,
        t.id                   AS tenantId,
        t.tenant_type          AS tenantType,
        t.code                 AS tenantCode,
        t.expiration_date      AS tenantExpirationDate,
        pg.code                AS parentGroupCode
        FROM owner o
        LEFT JOIN tenant t
        ON t.owner_id = o.id AND t.status = 'ACTIVE'
        LEFT JOIN tenant pg
        ON pg.id = t.parent_id AND pg.tenant_type = 'GROUP'
        ORDER BY o.owner_code ASC, t.tenant_type ASC, t.code ASC;
    </select>

    <insert id="addOwnerDetail" parameterType="com.eazycount.entity.Owner" useGeneratedKeys="true" keyProperty="id">
        insert into owner(owner_code, name, email, password, secondary_password, status, created_by)
        values(#{ownerCode}, #{name}, #{email}, #{password}, #{secondaryPassword}, #{status}, #{createdBy})
    </insert>

    <insert id="addTenantDetail" parameterType="com.eazycount.entity.Tenant" useGeneratedKeys="true" keyProperty="id">
        insert into tenant(tenant_type, code, name, owner_id, parent_id, expiration_date, status, created_by)
        values(#{tenantType}, #{code}, #{name}, #{ownerId}, #{parentId}, #{expirationDate}, #{status}, #{createdBy})
    </insert>

    <update id="updateOwnerDetail">
        update owner
        set owner_code = #{ownerCode},
            name = #{name},
            email = #{email},
            password = #{password},
            secondary_password = #{secondaryPassword}
        where id  = #{id}
    </update>

    <update id="updateTenantDetail">
        update tenant
        set tenant_type =#{tenantType},
            code = #{code},
            name = #{name},
            owner_id = #{ownerId},
            parent_id = #{parentId},
            expiration_date = #{expirationDate},
            status = #{status}
        where id  = #{id}
    </update>

    <select id="findFeeSetting" resultMap="DomainFeeMap">
        select * from domain_list_fee_settings
        where id = 1
    </select>

    <update id="updateFee">
        UPDATE domain_list_fee_settings
        SET company_price = #{companyPrice, typeHandler=com.eazycount.config.mybatis.PriceMapTypeHandler},
            group_price   = #{groupPrice, typeHandler=com.eazycount.config.mybatis.PriceMapTypeHandler},
            updated_at    = #{updatedTime}
        WHERE id = 1
    </update>
    
    <delete id="deleteOwner">
        delete from owner
        where id = #{ownerId}
    </delete>

    <delete id="deleteTenant">
        delete from tenant
        where id = #{tenantId}
    </delete>

    <delete id="deleteTenantFeatureModulesByTenantId">
        DELETE FROM tenant_feature_module
        WHERE tenant_id = #{tenantId}
    </delete>

    <delete id="deleteUserTenantAccessByTenantId">
        DELETE FROM user_tenant_access
        WHERE tenant_id = #{tenantId}
    </delete>

    <delete id="deleteAccountTenantAccessByTenantId">
        DELETE FROM account_tenant_access
        WHERE tenant_id = #{tenantId}
    </delete>

    <delete id="deleteTenantLinksByTenantId">
        DELETE FROM tenant_link
        WHERE tenant_id = #{tenantId}
        OR linked_tenant_id = #{tenantId}
    </delete>

    <delete id="deletePasswordResetTacByTenantId">
        DELETE FROM password_reset_tac
        WHERE tenant_id = #{tenantId}
    </delete>

    <delete id="deletePasswordResetTacOwnerByOwnerId">
        DELETE FROM password_reset_tac_owner
        WHERE owner_id = #{ownerId}
    </delete>
</mapper>
